# --- Metadata Extraction Service Configuration ---

# Optional: Your Google Cloud Project ID. If unset, ADC will try to infer it.
GCP_PROJECT_ID=your-gcp-project-id

# Optional: The GCP region for Vertex AI. If unset, uses Vertex AI default.
GCP_REGION=us-central1

# Required: The specific Vertex AI Gemini model name to use.
VERTEX_MODEL_NAME=google/gemini-2.5-flash-preview-04-17
# Example: VERTEX_MODEL_NAME=gemini-2.5-flash-preview-04-17

# --- Other potential config ---
VERTEX_OPENAI_ENDPOINT_URL=https://us-central1-aiplatform.googleapis.com/v1beta1/projects/your-gcp-project-id/locations/us-central1/endpoints/openapi
# VERTEX_API_KEY=your_actual_api_key_if_needed_later

# --- Other potential config ---
# Add other environment variables for the application here if needed.

TARGET_SA_NAME_OR_EMAIL="service-account@your-gcp-project-id.iam.gserviceaccount.com"

ENABLE_LOGFIRE=true